import javax.swing.*;   // imports all Swing components (JFrame, JPanel, JButton, JLabel...)
import java.awt.*;      // imports AWT tools (Color, Font, BorderLayout...)

public class welcomePanel {
    public static void main(String[] args) {

        // create the main window with the title "Quiz game"
        JFrame frame = new JFrame("Quiz game");

        // set the window size to 800 pixels wide and 600 pixels tall
        frame.setSize(800, 600);

        // make the program close completely when the X button is clicked
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);

        // create a panel to hold and organize all our components
        JPanel welcomePanel = new JPanel();

        // divide the panel into 5 zones: NORTH, SOUTH, EAST, WEST, CENTER
        welcomePanel.setLayout(new BorderLayout());

        // set the panel background color to black
        welcomePanel.setBackground(Color.BLACK);

        // create a button labeled "play"
        JButton button = new JButton("play");

        // set the button font to Times New Roman, plain style, size 35
        button.setFont(new Font("Times New Roman", Font.PLAIN, 35));

        // create a label with centered text for the welcome message
        JLabel label = new JLabel("Welcome to the Game", SwingConstants.CENTER);

        // set the label font to Times New Roman, plain style, size 34
        label.setFont(new Font("Times New Roman", Font.PLAIN, 34));

        // set the label text color to green
        label.setForeground(Color.GREEN);

        // add the label to the CENTER zone of the panel
        welcomePanel.add(label, BorderLayout.CENTER);

        // add the play button to the SOUTH (bottom) zone of the panel
        welcomePanel.add(button, BorderLayout.SOUTH);

        // add the panel into the frame so it appears in the window
        frame.add(welcomePanel);

        // make the frame visible — without this the window won't show up
        frame.setVisible(true);
    }
}
